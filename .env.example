# =============================================================================
# pgstat Konfigürasyonu
# =============================================================================
#
# KURULUM:
#   1. Bu dosyayı kopyalayın:  cp .env.example .env
#   2. Aşağıdaki değerleri ortamınıza göre düzenleyin
#   3. Çalıştırın:  ./pgstat setup
#
# =============================================================================
# MERKEZI POSTGRESQL BAĞLANTISI
# =============================================================================
# pgstat'ın topladığı verileri saklayacağı veritabanı.
# Bu, izlediğiniz kaynak PG'ler DEĞİL — pgstat'ın kendi deposu.
#
# Gereksinimler:
#   - PostgreSQL 14+ (17 önerilir)
#   - Aşağıdaki kullanıcının CREATEDB yetkisi olmalı (ilk kurulumda DB oluşturur)
#   - Veya pgstat DB'sini önceden oluşturup kullanıcıya tam yetki verin:
#
#     -- Seçenek 1: Kullanıcı DB'yi oluştursun
#     CREATE ROLE pgstat_admin LOGIN PASSWORD 'güçlü_şifre' CREATEDB;
#
#     -- Seçenek 2: DB'yi siz oluşturun, kullanıcıya yetki verin
#     CREATE ROLE pgstat_admin LOGIN PASSWORD 'güçlü_şifre';
#     CREATE DATABASE pgstat OWNER pgstat_admin;
#     \c pgstat
#     GRANT ALL ON SCHEMA public TO pgstat_admin;
#     GRANT CREATE ON SCHEMA public TO pgstat_admin;
#
#   Neden bu yetkiler gerekli:
#     - CREATE SCHEMA: migration'lar control, dim, fact, agg, ops schema'ları oluşturur
#     - CREATE TABLE: 28 tablo + 220+ partition oluşturulur
#     - INSERT/UPDATE/DELETE: collector veri yazar, API okur/yazar
#     - USAGE ON SCHEMA: tüm schema'lara erişim
#
PGSTAT_DB_HOST=localhost
PGSTAT_DB_PORT=5417
PGSTAT_DB_NAME=pgstat
PGSTAT_DB_USER=pgstat_admin
PGSTAT_DB_PASSWORD=güçlü_şifre_buraya

# =============================================================================
# UYGULAMA AYARLARI
# =============================================================================

# Şifreleme anahtarı — instance şifreleri AES-256 ile encrypt edilir
# ./pgstat setup ile otomatik üretilir
PGSTAT_SECRET_KEY=

# JWT secret'ları — ./pgstat setup ile otomatik üretilir (en az 32 karakter)
PGSTAT_JWT_SECRET=
PGSTAT_JWT_REFRESH_SECRET=

# Admin şifre hash'i — ./pgstat setup ile bcrypt olarak üretilir
# Manuel üretmek için: node -e "const b=require('bcryptjs');console.log(b.hashSync('şifren',12))"
PGSTAT_ADMIN_PASSWORD_HASH=

# API portu (UI bu porta proxy yapar)
API_PORT=3001

# UI portu (tarayıcıdan erişeceğiniz port)
UI_PORT=3000

# Collector hostname (ops.job_run tablosunda görünür)
COLLECTOR_HOSTNAME=collector-01

# =============================================================================
# KAYNAK POSTGRESQL KULLANICI GEREKSİNİMLERİ
# =============================================================================
# İzlemek istediğiniz her kaynak PG'de aşağıdaki kullanıcıyı oluşturun:
#
#   CREATE ROLE pgstats_collector
#     LOGIN PASSWORD 'şifre'
#     NOSUPERUSER NOCREATEDB NOCREATEROLE NOREPLICATION;
#
#   GRANT pg_read_all_stats TO pgstats_collector;
#   GRANT pg_read_all_settings TO pgstats_collector;
#   GRANT CONNECT ON DATABASE postgres TO pgstats_collector;
#
#   -- Tablo/index istatistikleri toplanacak her DB için:
#   GRANT CONNECT ON DATABASE mydb TO pgstats_collector;
#
# Kaynak PG gereksinimleri:
#   - shared_preload_libraries = 'pg_stat_statements'  (restart gerekir)
#   - CREATE EXTENSION pg_stat_statements;  (admin DB'de)
#
# Instance ekleme:
#   UI'dan Instances > + Instance Ekle ile ekleyin.
#   Kullanıcı adı ve şifre formda girilir.
# =============================================================================

# =============================================================================
# BİLDİRİM AYARLARI (Opsiyonel)
# =============================================================================
# Alert oluştuğunda bildirim göndermek için aşağıdaki ayarları yapılandırın.
# Kanal tanımları UI'dan yapılır (Adaptive Alerting > Bildirim Kanalları).

# SMTP (Email bildirimleri için)
PGSTAT_SMTP_HOST=smtp.gmail.com
PGSTAT_SMTP_PORT=587
PGSTAT_SMTP_USER=
PGSTAT_SMTP_PASSWORD=
PGSTAT_SMTP_AUTH=true
PGSTAT_SMTP_STARTTLS=true

# Telegram ve Teams ayarları UI'dan kanal eklerken girilir.
# Telegram: BotFather'dan bot_token alın, gruba ekleyin, chat_id'yi bulun.
# Teams: Incoming Webhook connector'ı ekleyin, webhook URL'ini kopyalayın.
