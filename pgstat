#!/bin/bash
# =============================================================================
# pgstat — PostgreSQL İstatistik Toplama Sistemi
#
#   ./pgstat setup        İlk kurulum (interaktif)
#   ./pgstat up           Başlat
#   ./pgstat down         Durdur
#   ./pgstat upgrade      Güncelle (migration + rebuild)
#   ./pgstat logs [srv]   Loglar
#   ./pgstat status       Durum
#   ./pgstat backup       DB backup
#   ./pgstat install      Systemd servisi kur
# =============================================================================

set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE="docker compose -f $DIR/docker-compose.prod.yml"
ENV_FILE="$DIR/.env"

G='\033[0;32m' Y='\033[1;33m' R='\033[0;31m' C='\033[0;36m' B='\033[1m' N='\033[0m'
ok()   { echo -e "${G}✓${N} $1"; }
warn() { echo -e "${Y}!${N} $1"; }
fail() { echo -e "${R}✗${N} $1"; exit 1; }
ask()  { read -rp "$(echo -e "${C}?${N} $1 ${Y}[$2]${N}: ")" val; echo "${val:-$2}"; }

load_env() {
  [ -f "$ENV_FILE" ] || fail ".env bulunamadı. Önce: ./pgstat setup"
  set -a; source "$ENV_FILE"; set +a
  # Opsiyonel degiskenler — set -u altinda unbound olmasinlar
  : "${UI_PORT:=3000}"
  : "${API_PORT:=3001}"
  : "${COLLECTOR_HOSTNAME:=collector-01}"
  : "${GRAFANA_ADMIN_USER:=admin}"
  : "${GRAFANA_ADMIN_PASSWORD:=pgstat-admin}"
  : "${GRAFANA_ROOT_URL:=http://localhost:${UI_PORT}/grafana/}"
  : "${PGSTAT_GRAFANA_DB_USER:=pgstat_grafana_ro}"
  : "${PGSTAT_GRAFANA_DB_PASSWORD:=}"
  export UI_PORT API_PORT COLLECTOR_HOSTNAME
  export GRAFANA_ADMIN_USER GRAFANA_ADMIN_PASSWORD GRAFANA_ROOT_URL
  export PGSTAT_GRAFANA_DB_USER PGSTAT_GRAFANA_DB_PASSWORD
}

gen_secret() {
  openssl rand -hex 32 2>/dev/null \
    || python3 -c "import secrets; print(secrets.token_hex(32))" 2>/dev/null \
    || head -c 64 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 64
}

do_migrate() {
  if ! PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
      -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
      -U "$PGSTAT_DB_USER" -d "$PGSTAT_DB_NAME" \
      -c "SELECT 1" > /dev/null 2>&1; then
    fail "DB bağlantısı kurulamıyor ($PGSTAT_DB_HOST:$PGSTAT_DB_PORT)"
  fi

  PG="PGPASSWORD=$PGSTAT_DB_PASSWORD psql -h $PGSTAT_DB_HOST -p $PGSTAT_DB_PORT -d $PGSTAT_DB_NAME -U $PGSTAT_DB_USER -tAc"

  # Migration tracking tablosu oluştur
  PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
    -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
    -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
    -c "CREATE TABLE IF NOT EXISTS public.schema_migrations (
          version text PRIMARY KEY,
          applied_at timestamptz NOT NULL DEFAULT now()
        )" > /dev/null 2>&1

  # İlk kez tracking ekleniyor ve DB zaten doluysa — mevcut migration'ları seed et
  row_count=$(PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
    -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
    -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
    -tAc "SELECT count(*) FROM public.schema_migrations" 2>/dev/null || echo "0")

  if [ "$row_count" = "0" ]; then
    # control schema varsa DB daha önce kurulmuş — hangi migration'lar uygulanmış tespit et
    schema_exists=$(PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
      -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
      -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
      -tAc "SELECT count(*) FROM information_schema.schemata WHERE schema_name='control'" 2>/dev/null || echo "0")

    if [ "$schema_exists" = "1" ]; then
      warn "Mevcut DB tespit edildi — migration geçmişi tohumlanıyor..."
      for f in "$DIR/db/migrations"/V*.sql; do
        fname=$(basename "$f")
        version="${fname%.sql}"
        # Her migration'ı çalıştırmayı dene (idempotent olmalı)
        # Başarılıysa applied olarak kaydet
        if PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
          -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
          -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
          -f "$f" -v ON_ERROR_STOP=1 > /dev/null 2>&1; then
          PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
            -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
            -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
            -c "INSERT INTO public.schema_migrations (version) VALUES ('$version') ON CONFLICT DO NOTHING" > /dev/null 2>&1
        else
          warn "  $fname hata verdi — sonraki upgrade'de tekrar denenecek"
        fi
      done
      ok "Migration geçmişi tohumlandı"
      return
    fi
  fi

  # Normal akış: sadece uygulanmamış migration'ları çalıştır
  applied=0
  skipped=0
  failed=0
  for f in "$DIR/db/migrations"/V*.sql; do
    fname=$(basename "$f")
    version="${fname%.sql}"

    already=$(PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
      -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
      -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
      -tAc "SELECT count(*) FROM public.schema_migrations WHERE version = '$version'" 2>/dev/null || echo "0")

    if [ "$already" = "1" ]; then
      skipped=$((skipped + 1))
      continue
    fi

    if PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
      -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
      -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
      -f "$f" -v ON_ERROR_STOP=1 > /dev/null 2>&1; then
      PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
        -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
        -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
        -c "INSERT INTO public.schema_migrations (version) VALUES ('$version')" > /dev/null 2>&1
      applied=$((applied + 1))
    else
      warn "  $fname uygulanırken hata — kontrol edin"
      failed=$((failed + 1))
    fi
  done
  ok "Migration tamamlandı ($applied yeni, $skipped atlandı, $failed hatalı)"

  # Grafana kullanicisinin durumunu kontrol et (rol yoksa kullaniciyi bilgilendir)
  role_exists=$(PGPASSWORD="$PGSTAT_DB_PASSWORD" psql \
    -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
    -d "$PGSTAT_DB_NAME" -U "$PGSTAT_DB_USER" \
    -tAc "SELECT 1 FROM pg_roles WHERE rolname='pgstat_grafana_ro'" 2>/dev/null || echo "")
  if [ -z "$role_exists" ]; then
    echo ""
    echo -e "${C}ℹ Grafana entegrasyonu icin pgstat_grafana_ro kullanicisi henuz olusturulmamis.${N}"
    echo -e "  Olusturmak icin: ${G}./pgstat setup-grafana${N} (superuser bilgisi sorulur)"
    echo -e "  Sonra tekrar:    ${G}./pgstat upgrade${N}"
  fi
}

do_health() {
  for i in $(seq 1 30); do
    curl -sf "http://localhost:${API_PORT:-3001}/api/health" > /dev/null 2>&1 && { ok "API hazır"; return; }
    sleep 2
  done
  warn "API henüz hazır değil — logları kontrol edin: ./pgstat logs api"
}

case "${1:-help}" in

  setup)
    echo -e "${B}═══════════════════════════════════════${N}"
    echo -e "${B}  pgstat Kurulum Sihirbazı${N}"
    echo -e "${B}═══════════════════════════════════════${N}"
    echo ""

    # Docker kontrolü
    if ! command -v docker &> /dev/null; then
      fail "Docker kurulu değil. Önce Docker kurun."
    fi
    if ! docker info > /dev/null 2>&1; then
      fail "Docker çalışmıyor. 'systemctl start docker' deneyin."
    fi

    if [ -f "$ENV_FILE" ]; then
      source "$ENV_FILE"
      warn ".env zaten var. Mevcut ayarlarla devam ediliyor."
      echo "  Sıfırdan başlamak için: rm .env && ./pgstat setup"
      echo ""
    else
      echo -e "${C}Merkezi PostgreSQL bağlantı bilgileri:${N}"
      echo "  (pgstat'ın veri saklayacağı DB — izlenen sunucular DEĞİL)"
      echo ""

      DB_HOST=$(ask "PostgreSQL host" "localhost")
      DB_PORT=$(ask "PostgreSQL port" "5417")
      DB_NAME=$(ask "Veritabanı adı" "pgstat")
      DB_USER=$(ask "Kullanıcı" "samet")
      read -rsp "$(echo -e "${C}?${N} DB Şifresi: ")" DB_PASS; echo ""

      if [[ ! "$DB_NAME" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
        fail "Geçersiz DB adı. Sadece harf, rakam ve alt çizgi."
      fi

      echo ""
      echo -e "${C}Uygulama ayarları:${N}"
      UI_P=$(ask "UI portu" "3000")
      API_P=$(ask "API portu" "3001")

      echo ""
      echo -e "${C}Admin şifresi (UI giriş için):${N}"
      while true; do
        read -rsp "$(echo -e "${C}?${N} Admin şifre (min 8 karakter): ")" ADMIN_PASS; echo ""
        if [ ${#ADMIN_PASS} -lt 8 ]; then
          warn "Şifre en az 8 karakter olmalı"
          continue
        fi
        read -rsp "$(echo -e "${C}?${N} Şifre tekrar: ")" ADMIN_PASS2; echo ""
        if [ "$ADMIN_PASS" = "$ADMIN_PASS2" ]; then
          break
        fi
        warn "Şifreler eşleşmiyor"
      done

      echo ""
      echo -e "${C}Grafana entegrasyonu (opsiyonel):${N}"
      echo "  pgstat UI ile aynı port üzerinden /grafana/ yolundan erişilir."
      echo "  Trend grafikleri, DoD/WoW karşılaştırması, top sorgu drill-down."
      read -rp "$(echo -e "${C}?${N} Grafana kurulsun mu? [Y/n]: ")" GRAFANA_ENABLE
      GRAFANA_ENABLE=${GRAFANA_ENABLE:-Y}
      if [[ "$GRAFANA_ENABLE" =~ ^[Yy]$ ]]; then
        GRAFANA_ADMIN_USR=$(ask "Grafana admin kullanıcı" "admin")
        read -rsp "$(echo -e "${C}?${N} Grafana admin şifre (boş = otomatik üret): ")" GR_ADMIN_PASS; echo ""
        [ -z "$GR_ADMIN_PASS" ] && GR_ADMIN_PASS=$(gen_secret | head -c 16)
        # DB read-only kullanici sifresi — otomatik
        GR_DB_PASS=$(gen_secret | head -c 24)
        # Root URL — otomatik tahmin
        HOST_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
        DEFAULT_URL="http://${HOST_IP:-localhost}:${UI_P}/grafana/"
        GR_ROOT_URL=$(ask "Grafana root URL" "$DEFAULT_URL")
      fi

      echo ""
      ok "Ayarlar hazırlanıyor..."

      cat > "$ENV_FILE" << EOF
# pgstat konfigürasyonu — $(date +%Y-%m-%d)
PGSTAT_DB_HOST=$DB_HOST
PGSTAT_DB_PORT=$DB_PORT
PGSTAT_DB_NAME=$DB_NAME
PGSTAT_DB_USER=$DB_USER
PGSTAT_DB_PASSWORD=$DB_PASS
PGSTAT_SECRET_KEY=$(gen_secret)
PGSTAT_JWT_SECRET=$(gen_secret)
PGSTAT_JWT_REFRESH_SECRET=$(gen_secret)
PGSTAT_ADMIN_PASSWORD=$ADMIN_PASS
API_PORT=$API_P
UI_PORT=$UI_P
COLLECTOR_HOSTNAME=$(hostname -s 2>/dev/null || echo "collector-01")
EOF
      if [[ "$GRAFANA_ENABLE" =~ ^[Yy]$ ]]; then
        cat >> "$ENV_FILE" << EOF

# Grafana entegrasyonu
GRAFANA_ADMIN_USER=$GRAFANA_ADMIN_USR
GRAFANA_ADMIN_PASSWORD=$GR_ADMIN_PASS
GRAFANA_ROOT_URL=$GR_ROOT_URL
PGSTAT_GRAFANA_DB_USER=pgstat_grafana_ro
PGSTAT_GRAFANA_DB_PASSWORD=$GR_DB_PASS
EOF
      fi
      chmod 600 "$ENV_FILE"
      ok ".env oluşturuldu"
    fi

    load_env

    # DB bağlantı testi
    echo ""
    echo -e "${C}Veritabanı kontrol ediliyor...${N}"
    if ! PGPASSWORD="$PGSTAT_DB_PASSWORD" psql -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" -U "$PGSTAT_DB_USER" -d "$PGSTAT_DB_NAME" -c "SELECT 1" > /dev/null 2>&1; then
      warn "pgstat DB bulunamadı, oluşturuluyor..."
      PGPASSWORD="$PGSTAT_DB_PASSWORD" psql -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" -U "$PGSTAT_DB_USER" -d postgres \
        -c "CREATE DATABASE $PGSTAT_DB_NAME" 2>/dev/null || fail "DB oluşturulamadı. Bağlantı bilgilerini kontrol edin."
    fi
    ok "DB bağlantısı OK"

    echo -e "${C}Tablolar oluşturuluyor...${N}"
    do_migrate

    # Grafana kurulumu istendiyse: superuser ile rol oluştur
    if [ -n "${PGSTAT_GRAFANA_DB_PASSWORD:-}" ]; then
      echo ""
      echo -e "${C}Grafana read-only kullanıcı oluşturuluyor (superuser bilgisi gerekli):${N}"
      read -rp "$(echo -e "${C}?${N} Superuser kullanıcı [postgres]: ")" SU_USER
      SU_USER=${SU_USER:-postgres}
      read -rsp "$(echo -e "${C}?${N} Superuser şifresi: ")" SU_PWD; echo ""
      if PGPASSWORD="$SU_PWD" psql \
          -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
          -U "$SU_USER" -d "$PGSTAT_DB_NAME" \
          -v ON_ERROR_STOP=1 \
          -v grafana_pwd="$PGSTAT_GRAFANA_DB_PASSWORD" \
          -f "$DIR/db/setup/grafana-user.sql" > /dev/null 2>&1; then
        ok "Grafana kullanıcı hazır"
        # Grant'leri uygula (V031 zaten uygulanmış olabilir, tekrar çalıştır)
        do_migrate > /dev/null 2>&1 || true
      else
        warn "Grafana kullanıcı oluşturulamadı — sonra ./pgstat setup-grafana çalıştır"
      fi
    fi

    echo -e "${C}Uygulama başlatılıyor (ilk build biraz sürebilir)...${N}"
    $COMPOSE up -d --build 2>&1 | tail -5
    do_health

    echo ""
    echo -e "${G}═══════════════════════════════════════${N}"
    echo -e "${G}  pgstat kurulumu tamamlandı!${N}"
    echo -e "${G}═══════════════════════════════════════${N}"
    echo ""
    HOST_IP=$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost)
    echo "  UI:      http://${HOST_IP}:${UI_PORT:-3000}"
    echo "  API:     http://localhost:${API_PORT:-3001}/api/health"
    if [ -n "${PGSTAT_GRAFANA_DB_PASSWORD:-}" ]; then
      echo "  Grafana: http://${HOST_IP}:${UI_PORT:-3000}/grafana/  (admin: ${GRAFANA_ADMIN_USER:-admin})"
    fi
    echo ""
    echo "  Komutlar: ./pgstat help"
    ;;

  up)      load_env; $COMPOSE up -d; do_health ;;
  down)    load_env; $COMPOSE down; ok "Durduruldu" ;;
  restart) load_env; $COMPOSE restart; do_health ;;

  upgrade)
    load_env
    [ -d "$DIR/.git" ] && git -C "$DIR" pull --ff-only 2>/dev/null || true
    do_migrate
    $COMPOSE up -d --build 2>&1 | tail -5
    do_health
    ok "Upgrade tamamlandı"
    ;;

  logs)   load_env; $COMPOSE logs -f --tail 50 ${2:-} ;;
  status) load_env; $COMPOSE ps ;;

  passwd)
    load_env
    while true; do
      read -rsp "Yeni admin şifre (min 8 karakter): " NP; echo ""
      [ ${#NP} -ge 8 ] && break
      warn "En az 8 karakter"
    done
    sed -i "s|^PGSTAT_ADMIN_PASSWORD=.*|PGSTAT_ADMIN_PASSWORD=$NP|" "$ENV_FILE"
    $COMPOSE restart api
    ok "Şifre değiştirildi"
    ;;

  backup)
    load_env
    mkdir -p "$DIR/backups"
    F="$DIR/backups/pgstat_$(date +%Y%m%d_%H%M%S).sql.gz"
    PGPASSWORD="$PGSTAT_DB_PASSWORD" pg_dump \
      -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
      -U "$PGSTAT_DB_USER" -d "$PGSTAT_DB_NAME" \
      --no-owner --no-privileges | gzip > "$F"
    ok "Backup: $F ($(du -h "$F" | cut -f1))"
    find "$DIR/backups" -name "pgstat_*.sql.gz" -mtime +30 -delete 2>/dev/null || true
    ;;

  migrate) load_env; do_migrate ;;

  setup-grafana)
    # Grafana read-only kullanicisini olustur (superuser ile, tek seferlik)
    load_env
    # Eksik Grafana env'lerini interaktif sor ve .env'e ekle
    if [ -z "${PGSTAT_GRAFANA_DB_PASSWORD:-}" ]; then
      echo -e "${C}Grafana ayarları .env'de yok — şimdi ekleniyor:${N}"
      GRAFANA_ADMIN_USR=$(ask "Grafana admin kullanıcı" "admin")
      read -rsp "$(echo -e "${C}?${N} Grafana admin şifre (boş = otomatik): ")" GR_ADMIN_PASS; echo ""
      [ -z "$GR_ADMIN_PASS" ] && GR_ADMIN_PASS=$(gen_secret | head -c 16)
      GR_DB_PASS=$(gen_secret | head -c 24)
      HOST_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
      GR_ROOT_URL=$(ask "Grafana root URL" "http://${HOST_IP:-localhost}:${UI_PORT}/grafana/")
      cat >> "$ENV_FILE" << EOF

# Grafana entegrasyonu — $(date +%Y-%m-%d)
GRAFANA_ADMIN_USER=$GRAFANA_ADMIN_USR
GRAFANA_ADMIN_PASSWORD=$GR_ADMIN_PASS
GRAFANA_ROOT_URL=$GR_ROOT_URL
PGSTAT_GRAFANA_DB_USER=pgstat_grafana_ro
PGSTAT_GRAFANA_DB_PASSWORD=$GR_DB_PASS
EOF
      ok "Grafana ayarları .env'e eklendi"
      load_env
    fi
    echo ""
    echo -e "${C}Grafana read-only kullanıcı oluşturuluyor (superuser bilgisi gerekli):${N}"
    read -rp "$(echo -e "${C}?${N} Superuser kullanıcı [postgres]: ")" SU_USER
    SU_USER=${SU_USER:-postgres}
    read -rsp "$(echo -e "${C}?${N} Superuser şifresi: ")" SU_PWD; echo ""
    if PGPASSWORD="$SU_PWD" psql \
        -h "$PGSTAT_DB_HOST" -p "$PGSTAT_DB_PORT" \
        -U "$SU_USER" -d "$PGSTAT_DB_NAME" \
        -v grafana_pwd="$PGSTAT_GRAFANA_DB_PASSWORD" \
        -f "$DIR/db/setup/grafana-user.sql" 2>&1; then
      ok "Grafana kullanıcı hazır"
      echo ""
      echo -e "${C}Migration grant'leri uygulanıyor...${N}"
      do_migrate
      echo ""
      echo -e "${C}Grafana container başlatılıyor...${N}"
      $COMPOSE up -d grafana 2>&1 | tail -3
      # UI nginx config'inde /grafana/ proxy bloğu — image'a build sırasında
      # gömülür, restart yetmez, --build gerekiyor
      echo -e "${C}UI nginx config rebuild ediliyor (Grafana proxy için)...${N}"
      $COMPOSE up -d --build ui 2>&1 | tail -3
      ok "Grafana hazır: $GRAFANA_ROOT_URL"
    else
      fail "Grafana kullanıcı oluşturulamadı"
    fi
    ;;

  install)
    INSTALL_DIR="/opt/pgstat"
    [ "$DIR" != "$INSTALL_DIR" ] && { sudo mkdir -p "$INSTALL_DIR"; sudo cp -r "$DIR"/* "$INSTALL_DIR/"; [ -f "$DIR/.env" ] && sudo cp "$DIR/.env" "$INSTALL_DIR/.env"; }
    sudo chmod 700 "$INSTALL_DIR"
    sudo chmod 600 "$INSTALL_DIR/.env" 2>/dev/null || true
    sudo cp "$INSTALL_DIR/pgstat.service" /etc/systemd/system/pgstat.service
    sudo systemctl daemon-reload
    sudo systemctl enable pgstat
    sudo systemctl start pgstat
    ok "Servis kuruldu — boot'ta otomatik başlar"
    ;;

  uninstall)
    sudo systemctl stop pgstat 2>/dev/null || true
    sudo systemctl disable pgstat 2>/dev/null || true
    sudo rm -f /etc/systemd/system/pgstat.service
    sudo systemctl daemon-reload
    ok "Servis kaldırıldı"
    ;;

  *)
    echo -e "${B}pgstat${N} — PostgreSQL İstatistik Toplama Sistemi"
    echo ""
    echo "Kullanım: ./pgstat <komut>"
    echo ""
    echo -e "  ${G}setup${N}       İlk kurulum (interaktif)"
    echo -e "  ${G}up${N}          Başlat"
    echo -e "  ${G}down${N}        Durdur"
    echo -e "  ${G}restart${N}     Yeniden başlat"
    echo -e "  ${G}upgrade${N}     Güncelle (git pull + rebuild)"
    echo -e "  ${G}logs${N} [srv]  Loglar (./pgstat logs collector)"
    echo -e "  ${G}status${N}      Container durumları"
    echo -e "  ${G}passwd${N}      Admin şifresini değiştir"
    echo -e "  ${G}backup${N}      DB backup al"
    echo -e "  ${G}migrate${N}     Sadece migration çalıştır"
    echo -e "  ${G}setup-grafana${N} Grafana read-only kullanıcısını oluştur (superuser ile)"
    echo -e "  ${G}install${N}     Systemd servisi kur"
    echo -e "  ${G}uninstall${N}   Servisi kaldır"
    echo ""
    echo -e "${Y}Merkezi DB yetkileri:${N}"
    echo "  CREATE ROLE pgstat_admin LOGIN PASSWORD '...' CREATEDB;"
    echo "  -- veya DB'yi oluşturup yetki verin"
    echo ""
    echo -e "${Y}Kaynak PG gereksinimleri:${N}"
    echo "  CREATE ROLE pgstats_collector LOGIN PASSWORD '...';"
    echo "  GRANT pg_read_all_stats TO pgstats_collector;"
    echo "  GRANT pg_read_all_settings TO pgstats_collector;"
    echo "  shared_preload_libraries = 'pg_stat_statements'"
    ;;
esac
